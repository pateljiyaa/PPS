#include <stdio.h>

// Recursive function
int factRecursive(int n) {
    if (n == 0)
        return 1;
    return n * factRecursive(n - 1);
}

// Iterative function
int factIterative(int n) {
    int i, fact = 1;
    for (i = 1; i <= n; i++) {
        fact = fact * i;
    }
    return fact;
}

int main() {
    int n, choice;

    printf("Enter number: ");
    scanf("%d", &n);

    if (n < 0) {
        printf("Invalid input\n");
        return 0;
    }

    printf("1. Iterative\n2. Recursive\nEnter choice: ");
    scanf("%d", &choice);

    if (choice == 1)
        printf("Factorial = %d", factIterative(n));
    else if (choice == 2)
        printf("Factorial = %d", factRecursive(n));
    else
        printf("Wrong choice");

    return 0;
}